---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="logo">
			<a href="/">{SITE_TITLE}</a><span class="cursor">_</span>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">~/home</HeaderLink>
			<HeaderLink href="/blog">~/blog</HeaderLink>
			<HeaderLink href="/about">~/about</HeaderLink>
		</div>
		<div class="right-block">
			<div class="controls">
				<button id="theme-toggle" aria-label="Toggle dark mode" title="Cambiar tema">[theme]</button>
				<button id="text-dec" aria-label="Decrease text size" title="Disminuir texto">[A-]</button>
				<button id="text-inc" aria-label="Increase text size" title="Aumentar texto">[A+]</button>
			</div>
			<div class="social-links">
				<a href="https://github.com/rrortega" target="_blank" rel="noopener noreferrer">[github]</a>
			</div>
		</div>
	</nav>
</header>

<script>
	const themeToggle = document.getElementById('theme-toggle');
	const textDec = document.getElementById('text-dec');
	const textInc = document.getElementById('text-inc');

	themeToggle?.addEventListener('click', () => {
		const currentTheme = document.documentElement.getAttribute('data-theme') || 
			(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
		const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
		document.documentElement.setAttribute('data-theme', newTheme);
		localStorage.setItem('theme', newTheme);
	});

	const changeScale = (delta: number) => {
		const currentScale = parseFloat(document.documentElement.style.getPropertyValue('--text-scale') || '1');
		const newScale = Math.min(Math.max(currentScale + delta, 0.8), 1.4);
		const fixedScale = newScale.toFixed(1);
		document.documentElement.style.setProperty('--text-scale', fixedScale);
		localStorage.setItem('text-scale', fixedScale);
	};

	textDec?.addEventListener('click', () => changeScale(-0.1));
	textInc?.addEventListener('click', () => changeScale(0.1));
</script>

<style>
	header {
		margin: 0;
		padding: 1.5rem 1rem;
		background: transparent;
	}
	nav {
		width: 800px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-bottom: 1rem;
		border-bottom: 1px dashed var(--border);
	}
	.logo a {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 1.1rem;
		color: var(--text);
		text-decoration: none;
	}
	.cursor {
		font-family: var(--font-mono);
		color: var(--accent);
		animation: blink 1s step-end infinite;
		font-weight: 700;
	}
	.internal-links {
		display: flex;
		gap: 1.5rem;
	}
	.right-block {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}
	.controls {
		display: flex;
		gap: 0.5rem;
	}
	.controls button {
		background: none;
		border: none;
		padding: 0;
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: var(--text-muted);
		cursor: pointer;
		transition: color 0.15s ease;
	}
	.controls button:hover {
		color: var(--accent);
	}
	.social-links a {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: var(--text-muted);
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@keyframes blink {
		from, to { color: transparent }
		50% { color: var(--accent) }
	}
	@media (max-width: 600px) {
		nav {
			flex-direction: column;
			gap: 1rem;
			align-items: flex-start;
		}
		.right-block {
			width: 100%;
			justify-content: space-between;
		}
	}
</style>
