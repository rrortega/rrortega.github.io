---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<span>&copy; {today.getFullYear()} Rolo. Built with Astro.</span>
		<div class="links">
			<a href="https://github.com/rrortega" target="_blank" rel="noopener noreferrer">github</a>
			<span class="sep">/</span>
			<a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">linkedin</a>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: auto;
		padding: 2.5rem 1rem;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.footer-content {
		width: 800px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1.5rem;
		border-top: 1px dashed var(--border);
	}
	.links {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	.links a {
		color: var(--text-muted);
	}
	.links a:hover {
		color: var(--accent);
	}
	.sep {
		color: var(--border);
	}
	@media (max-width: 600px) {
		.footer-content {
			flex-direction: column;
			gap: 0.75rem;
			align-items: flex-start;
		}
	}
</style>
