---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<div class="terminal-badge">dev.status = "active"</div>
				<h1>Hola, soy Rolo.</h1>
				<p class="subtitle">CEO at CHAMBAPRO | AI & Process Automation Consultant</p>
				<p>
					Bienvenido a mi rincón digital. Acá escribo sobre desarrollo de software, 
					automatización de procesos, arquitectura de sistemas y las tecnologías que voy probando. 
					Pero también voy a dejar reflexiones sinceras: cosas que construyo y de las que estoy orgulloso, 
					proyectos que fallaron estrepitosamente (y por qué), y pensamientos bastante frikis sobre tecnología y la vida.
				</p>
				<p class="warning-text">
					<strong>Advertencia amigable:</strong> si no eres tan friki como yo, quizás esto no sea para ti. 
					No me hago responsable si después de leer empiezas a ver patrones donde no los hay o te obsesionas 
					con la elegancia de una línea de código. Has sido avisado.
				</p>
			</section>

			<hr />

			<section class="posts-section">
				<h2>Artículos</h2>
				<ul class="post-list">
					{
						posts.map((post, index) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-link">
									<article class="post-card">
										{post.data.heroImage && (
											<div class="post-image-container">
												<Image src={post.data.heroImage} alt="" class="post-card-img" loading={index === 0 ? "eager" : "lazy"} />
											</div>
										)}
										<div class="post-card-body">
											<div class="post-meta">
												<FormattedDate date={post.data.pubDate} />
											</div>
											<h3 class="post-title">{post.data.title}</h3>
											{post.data.description && <p class="post-desc">{post.data.description}</p>}
											<div class="post-cta">
												<span>&lt;/Echate el play&gt;</span>
											</div>
										</div>
									</article>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		padding: 2rem 0;
	}
	.terminal-badge {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		padding: 0.25rem 0.6rem;
		background-color: var(--accent-subtle);
		border: 1px solid var(--accent);
		border-radius: 4px;
		color: var(--accent);
		margin-bottom: 1.5rem;
	}
	.subtitle {
		font-family: var(--font-mono);
		font-size: 1.15rem;
		color: var(--text-muted);
		margin-top: -0.5rem;
		margin-bottom: 1.5rem;
	}
	.warning-text {
		font-size: 0.9rem;
		color: var(--text-muted);
		border-left: 2px solid var(--accent-subtle);
		padding-left: 1rem;
		margin-top: 1rem;
	}
	.posts-section {
		margin-top: 2rem;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}
	.post-link {
		color: inherit;
		text-decoration: none;
		display: block;
	}
	.post-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--border);
		border-radius: 12px;
		overflow: hidden;
		background: rgba(var(--accent-rgb), 0.01);
		transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.2s;
	}
	.post-link:hover .post-card {
		transform: translateY(-6px);
		border-color: var(--accent);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
	}
	.post-image-container {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-bottom: 1px solid var(--border);
	}
	.post-card-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}
	.post-link:hover .post-card-img {
		transform: scale(1.02);
	}
	.post-card-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.post-meta {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-muted);
	}
	.post-title {
		margin: 0;
		font-size: 1.35rem;
		font-weight: 600;
		transition: color 0.15s ease;
	}
	.post-link:hover .post-title {
		color: var(--accent);
	}
	.post-desc {
		margin: 0;
		font-size: 0.95rem;
		color: var(--text-muted);
		line-height: 1.6;
	}
	.post-cta {
		margin-top: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--accent);
		font-weight: 600;
		display: flex;
		align-items: center;
	}
	@media (max-width: 600px) {
		.post-card-body {
			padding: 1.25rem;
		}
		.post-title {
			font-size: 1.2rem;
		}
	}
</style>
