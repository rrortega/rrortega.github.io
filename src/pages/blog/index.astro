---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-header">
				<div class="terminal-badge">~/artículos</div>
				<h1>Bitácora</h1>
				<p class="subtitle">Pensamientos, tutoriales y apuntes técnicos.</p>
			</section>

			<section class="posts-section">
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-link">
									<article class="post-card">
										<div class="post-meta">
											<span class="post-date">
												<FormattedDate date={post.data.pubDate} />
											</span>
										</div>
										<div class="post-content">
											<h3 class="post-title">{post.data.title}</h3>
											{post.data.description && <p class="post-desc">{post.data.description}</p>}
										</div>
										<span class="post-arrow">&rarr;</span>
									</article>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-header {
		padding: 2rem 0;
	}
	.terminal-badge {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		padding: 0.25rem 0.6rem;
		background-color: var(--accent-subtle);
		border: 1px solid var(--accent);
		border-radius: 4px;
		color: var(--accent);
		margin-bottom: 1.5rem;
	}
	.subtitle {
		font-family: var(--font-mono);
		font-size: 1.1rem;
		color: var(--text-muted);
		margin-top: -0.5rem;
		margin-bottom: 0;
	}
	.posts-section {
		margin-top: 2rem;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.post-list li {
		border-bottom: 1px dashed var(--border);
	}
	.post-list li:last-child {
		border-bottom: none;
	}
	.post-link {
		color: inherit;
		text-decoration: none;
		display: block;
	}
	.post-card {
		display: flex;
		padding: 1.75rem 0;
		position: relative;
		transition: transform 0.2s ease;
	}
	.post-link:hover .post-card {
		transform: translateX(8px);
	}
	.post-link:hover .post-title {
		color: var(--accent);
	}
	.post-meta {
		width: 140px;
		flex-shrink: 0;
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.post-content {
		flex-grow: 1;
		padding-right: 2rem;
	}
	.post-title {
		margin: 0 0 0.5rem 0;
		font-size: 1.25rem;
		font-weight: 600;
		transition: color 0.15s ease;
	}
	.post-desc {
		margin: 0;
		font-size: 0.95rem;
		color: var(--text-muted);
		line-height: 1.5;
	}
	.post-arrow {
		position: absolute;
		right: 0;
		top: 50%;
		transform: translateY(-50%) translateX(-10px);
		color: var(--accent);
		opacity: 0;
		transition: opacity 0.2s ease, transform 0.2s ease;
	}
	.post-link:hover .post-arrow {
		opacity: 1;
		transform: translateY(-50%) translateX(0);
	}
	@media (max-width: 600px) {
		.post-card {
			flex-direction: column;
			gap: 0.5rem;
			padding: 1.25rem 0;
		}
		.post-meta {
			width: auto;
		}
		.post-content {
			padding-right: 0;
		}
		.post-arrow {
			display: none;
		}
	}
</style>
